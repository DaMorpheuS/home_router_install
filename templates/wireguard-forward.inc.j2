{% if (wireguard_peers | length > 0) or (wireguard_site_peers | default([]) | length > 0) %}
{% if wireguard_peers | length > 0 %}
{% for peer in wireguard_peers %}
{% set peer_ip = peer.address.split('/')[0] %}
                  # WireGuard peer {{ peer.name }}
{% if peer.access | default('') == 'all' %}
                  iifname "{{ wireguard_interface }}" ip saddr {{ peer_ip }} ip daddr $VLAN2_NET accept
                  iifname "{{ wireguard_interface }}" ip saddr {{ peer_ip }} ip daddr $VLAN3_NET accept
                  iifname "{{ wireguard_interface }}" ip saddr {{ peer_ip }} ip daddr $VLAN4_NET accept
{% if wireguard_admin_include_guest_vlan | default(true) %}
                  iifname "{{ wireguard_interface }}" ip saddr {{ peer_ip }} ip daddr $VLAN5_NET accept
{% endif %}
{% elif peer.vlans is defined and peer.vlans | length > 0 %}
{% for vid in peer.vlans %}
                  iifname "{{ wireguard_interface }}" ip saddr {{ peer_ip }} ip daddr $VLAN{{ vid }}_NET accept
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% for site in wireguard_site_peers | default([]) %}
{% for net in site.allowed_ips %}
                  # Site-to-site {{ site.name }} ({{ net }})
                  iifname "{{ wireguard_interface }}" ip saddr {{ net }} ip daddr $VLAN2_NET accept
                  iifname "{{ wireguard_interface }}" ip saddr {{ net }} ip daddr $VLAN3_NET accept
                  iifname "{{ wireguard_interface }}" ip saddr {{ net }} ip daddr $VLAN4_NET accept
                  iifname "{{ wireguard_interface }}" ip saddr {{ net }} ip daddr $VLAN5_NET accept
                  ip saddr $VLAN2_NET ip daddr {{ net }} oifname "{{ wireguard_interface }}" accept
                  ip saddr $VLAN3_NET ip daddr {{ net }} oifname "{{ wireguard_interface }}" accept
                  ip saddr $VLAN4_NET ip daddr {{ net }} oifname "{{ wireguard_interface }}" accept
                  ip saddr $VLAN5_NET ip daddr {{ net }} oifname "{{ wireguard_interface }}" accept
{% endfor %}
{% endfor %}
{% if wireguard_peers | length > 0 %}
{% if wireguard_allow_internet | default(true) %}
                  iifname "{{ wireguard_interface }}" ip saddr $WG_NET oifname "{{ wan_interface }}" accept comment "WireGuard internet"
{% endif %}
{% endif %}
{% else %}
                  # WireGuard — no peers configured (wireguard.yml)
{% endif %}
